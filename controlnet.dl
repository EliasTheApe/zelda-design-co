// ════════════════════════════════════════════════════════════
// DERIVED RULES — Geometry, Parity & Validation
// ════════════════════════════════════════════════════════════

// ── Bounding box (axis-aligned, ignores rotation — for layout checking only)
.decl bbox(id: EID, x0: float, y0: float, x1: float, y1: float)
bbox(id, x, y, x+w, y+h) :-
    pos(id, x, y),
    size(id, w, h).

// ── Right edge (% vw); > 100 = bleeds off right
.decl right_edge(id: EID, xe: float)
right_edge(id, x+w) :- pos(id, x, _), size(id, w, _).

// ── Bottom edge (px from top)
.decl bottom_edge(id: EID, ye: float)
bottom_edge(id, y+h) :- pos(id, _, y), size(id, _, h).

// ── Axis-aligned overlap between two distinct elements
.decl overlaps_aa(a: EID, b: EID)
overlaps_aa(a, b) :-
    bbox(a, ax0, ay0, ax1, ay1),
    bbox(b, bx0, by0, bx1, by1),
    a != b,
    ax0 < bx1, ax1 > bx0,
    ay0 < by1, ay1 > by0.

// ── Designer-declared intentional overlaps (suppresses unintentional_overlap warning)
.decl intentional_overlap(a: EID, b: EID)
intentional_overlap("hero_bg_image",     "hero_image_frame").
intentional_overlap("hero_bg_image",     "hero_title_l1").
intentional_overlap("hero_bg_image",     "hero_title_l2").
intentional_overlap("hero_bg_image",     "hero_subtitle").
intentional_overlap("hero_bg_image",     "hero_rule").
intentional_overlap("hero_bg_image",     "hero_cta").
intentional_overlap("hero_bg_image",     "hero_scroll_hint").
intentional_overlap("about_image_main",  "about_image_accent").
intentional_overlap("about_image_main",  "about_section_no").
intentional_overlap("about_image_main",  "about_bg").
intentional_overlap("projects_img_1",    "projects_img_2").
intentional_overlap("projects_img_2",    "projects_img_3").
intentional_overlap("projects_img_3",    "projects_img_4").
intentional_overlap("testimonials_bg",   "testimonials_quote_mark").
// All section_no decorative numbers are intentionally behind content
intentional_overlap("services_section_no",   "services_title").
intentional_overlap("process_section_no",    "process_title").
intentional_overlap("projects_section_no",   "projects_title").
intentional_overlap("testimonials_section_no","testimonials_quote").
intentional_overlap("contact_section_no",    "contact_title").

// ── Unintentional overlap: pairs that overlap but are NOT declared intentional
//    Output this to catch layout errors
.decl unintentional_overlap(a: EID, b: EID)
unintentional_overlap(a, b) :-
    overlaps_aa(a, b),
    !intentional_overlap(a, b),
    !intentional_overlap(b, a),
    a < b.    // deduplicate (a,b) and (b,a)

// ── Elements bleeding off the right edge (intentional ones are known)
.decl bleeds_right(id: EID, xe: float)
bleeds_right(id, xe) :- right_edge(id, xe), xe > 100.0.

// ── Elements bleeding below scroll canvas
.decl bleeds_bottom(id: EID, ye: float)
bleeds_bottom(id, ye) :- bottom_edge(id, ye), scroll_height(h), ye > h.

// ── Section element count (completeness audit)
.decl section_element_count(sid: SID, label: symbol, n: number)
section_element_count(sid, label, n) :-
    section(sid, label, _),
    n = count : { in_section(_, sid) }.

// ── Parity: each declared element must have pos + size + layer + rotation
.decl has_pos(id: EID)    has_pos(id)   :- pos(id, _, _).
.decl has_size(id: EID)   has_size(id)  :- size(id, _, _).
.decl has_layer(id: EID)  has_layer(id) :- layer(id, _).
.decl has_rot(id: EID)    has_rot(id)   :- rotation(id, _).

.decl layout_complete(id: EID)
layout_complete(id) :-
    element(id, _),
    has_pos(id), has_size(id), has_layer(id), has_rot(id).

.decl layout_incomplete(id: EID)
layout_incomplete(id) :- element(id, _), !layout_complete(id).

// ── Hover bounding box: effective screen area including hover translation offset
//    Only handles single hover_translate per element (most common case)
.decl hover_bbox(id: EID, x0: float, y0: float, x1: float, y1: float)
hover_bbox(id, x0+dx, y0+dy, x1+dx, y1+dy) :-
    bbox(id, x0, y0, x1, y1),
    hover_translate(id, dx, dy, _, _).

// ── Parallax drift: maximum vertical drift for parallax element over full scroll
//    drift = scroll_height * |1 - speed| (rough bound; assumes element visible throughout)
.decl parallax_drift_bound(id: EID, spd: float, max_drift: float)
parallax_drift_bound(id, spd, drift) :-
    parallax(id, spd),
    scroll_height(sh),
    drift = sh * (1.0 - spd).   // negative drift = floats up

// ── Sticky elements: must have top_offset ≥ 0 (sanity check)
.decl sticky_valid(id: EID)
sticky_valid(id) :- sticky(id, off), off >= 0.0.

.decl sticky_invalid(id: EID)
sticky_invalid(id) :- sticky(id, _), !sticky_valid(id).

// ── Elements with magnetic effect — their bbox is their "capture zone"
.decl magnetic_zone(id: EID, x0: float, y0: float, x1: float, y1: float, dist: float)
magnetic_zone(id, x0-dist, y0-dist, x1+dist, y1+dist, dist) :-
    bbox(id, x0, y0, x1, y1),
    magnetic(id, _, dist).


// ════════════════════════════════════════════════════════════
// OUTPUTS  (Souffle will write these as TSV files)
// ════════════════════════════════════════════════════════════

.output layout_incomplete        // PARITY: elements missing geometry declarations
.output unintentional_overlap    // LAYOUT: unexpected overlaps to review
.output bleeds_right             // INFO:   elements with off-page right bleed
.output bleeds_bottom            // ERROR:  elements below scroll canvas
.output sticky_invalid           // ERROR:  malformed sticky offsets
.output section_element_count    // AUDIT:  how many elements per section
.output hover_bbox               // DEBUG:  effective hover bounding boxes
.output parallax_drift_bound     // DEBUG:  max vertical drift per parallax element
.output magnetic_zone            // DEBUG:  cursor capture zones for magnetic elements
