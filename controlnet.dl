// ============================================================
// CONTROLNET.DL
// Interior Designer Landing Page — Layout Blueprint v1.0
//
// Coordinate system
// ─────────────────
//   x, w  → % of viewport width   (float; 0.0=left edge, 100.0=right edge;
//                                   values >100 or <0 = intentional off-page bleed)
//   y, h  → px from page top      (float; absolute scroll-space)
//   rot   → degrees               (float; CW positive, CCW negative)
//   z     → z-index layer         (number; higher = in front)
//   alpha → opacity               (float; 0.0=invisible, 1.0=opaque)
//   dur   → milliseconds          (float)
//   spd   → parallax speed factor (float; 0.0=fixed, 1.0=normal, <1=floats up)
//
// Baseline viewport  : 1440 × 900 px  (desktop)
// Total scroll height: 3700 px        ≈ 4.1 × viewport height
//
// Section y-ranges (approx)
//   HOME          y    0 –  900
//   ABOUT         y  900 – 1500
//   SERVICES      y 1500 – 2100
//   PROCESS       y 2100 – 2660
//   PROJECTS      y 2660 – 3060
//   TESTIMONIALS  y 3060 – 3260
//   CONTACT       y 3260 – 3500
//   FOOTER        y 3500 – 3700
// ============================================================


// ────────────────────────────────────────────────────────────
// TYPES
// ────────────────────────────────────────────────────────────

.type EID     <: symbol   // element identifier
.type SID     <: symbol   // section identifier
.type Easing  <: symbol   // "ease" | "ease-in" | "ease-out" | "ease-in-out" | "linear"
.type Axis    <: symbol   // "x" | "y" | "rot"
.type Action  <: symbol   // on_click target


// ────────────────────────────────────────────────────────────
// SCHEMA — STRUCTURAL
// ────────────────────────────────────────────────────────────

// Every element with its semantic kind
// kind: nav | hero | section | text | image | button | rule | icon |
//       menu_item | footer_link | social_link | footer | overlay
.decl element(id: EID, kind: symbol)

// Logical sections (scroll anchors)
.decl section(id: SID, label: symbol, anchor_y: float)

// Element → section membership
.decl in_section(eid: EID, sid: SID)

// Position: top-left corner of element bounding box in scroll-space
.decl pos(id: EID, x: float, y: float)

// Size
.decl size(id: EID, w: float, h: float)

// CSS transform: rotation about anchor point
.decl rotation(id: EID, deg: float)

// Transform-origin as % within element  (0,0=top-left  50,50=center  100,100=bottom-right)
.decl anchor(id: EID, ax: float, ay: float)

// Z-index layer
.decl layer(id: EID, z: number)

// Opacity (only declare when ≠ 1.0)
.decl opacity(id: EID, alpha: float)

// Sticky: element is position:sticky, sticks at `top_offset` px from viewport top
.decl sticky(id: EID, top_offset: float)

// Parent-child containment (layout grouping; child coords are in parent scroll-space)
.decl contains(parent: EID, child: EID)


// ────────────────────────────────────────────────────────────
// SCHEMA — INTERACTIONS
// ────────────────────────────────────────────────────────────

// Hover: translate (dx in vw%, dy in px)
.decl hover_translate(id: EID, dx: float, dy: float, dur: float, ease: Easing)

// Hover: rotation delta in degrees
.decl hover_rotate(id: EID, delta_deg: float, dur: float, ease: Easing)

// Hover: scale (sx, sy as multipliers; 1.0 = no change)
.decl hover_scale(id: EID, sx: float, sy: float, dur: float, ease: Easing)

// Hover: opacity target (to_alpha)
.decl hover_opacity(id: EID, to_alpha: float, dur: float, ease: Easing)

// Hover jiggle: oscillates on axis; amplitude in px (x/y) or deg (rot); freq in Hz
.decl hover_jiggle(id: EID, axis: Axis, amplitude: float, freq: float)

// Scroll parallax: element moves at spd × scroll speed
.decl parallax(id: EID, spd: float)

// Scroll-triggered fade-in: fires when `threshold` fraction of element is visible
.decl scroll_fade_in(id: EID, threshold: float, dur: float, ease: Easing)

// Scroll-triggered slide-in: element translates from (from_dx vw%, from_dy px) to rest pos
.decl scroll_slide_in(id: EID, from_dx: float, from_dy: float, threshold: float, dur: float, ease: Easing)

// Magnetic cursor: element drifts toward cursor within max_dist px, strength 0–1
.decl magnetic(id: EID, strength: float, max_dist: float)

// Click action
.decl on_click(id: EID, action: Action)


// ────────────────────────────────────────────────────────────
// CANVAS CONSTANTS
// ────────────────────────────────────────────────────────────

.decl viewport(w: float, h: float)
viewport(1440.0, 900.0).

.decl scroll_height(h: float)
scroll_height(3700.0).


// ════════════════════════════════════════════════════════════
// SECTIONS
// ════════════════════════════════════════════════════════════

section("sec_home",         "HOME",         0.0).
section("sec_about",        "ABOUT",        900.0).
section("sec_services",     "SERVICES",     1500.0).
section("sec_process",      "PROCESS",      2100.0).
section("sec_projects",     "PROJECTS",     2660.0).
section("sec_testimonials", "TESTIMONIALS", 3060.0).
section("sec_contact",      "CONTACT",      3260.0).
section("sec_footer",       "FOOTER",       3500.0).


// ════════════════════════════════════════════════════════════
// NAV BAR   (sticky, always on top)
// ════════════════════════════════════════════════════════════
//
//  ┌─────────────────────────────────────────────────────────┐  y=0
//  │ [LOGO]      HOME  ABOUT  SERVICES  PROCESS  PROJECTS    │  h=72
//  │                          TESTIMONIALS          CONTACT  │
//  └─────────────────────────────────────────────────────────┘

element("nav_bar",               "nav").
element("nav_logo",              "text").
element("nav_menu",              "nav").
element("nav_item_home",         "menu_item").
element("nav_item_about",        "menu_item").
element("nav_item_services",     "menu_item").
element("nav_item_process",      "menu_item").
element("nav_item_projects",     "menu_item").
element("nav_item_testimonials", "menu_item").
element("nav_item_contact",      "menu_item").

// nav_bar: full-width, 72px, sticky at viewport top
pos("nav_bar",   0.0,  0.0).  size("nav_bar",  100.0,  72.0).
layer("nav_bar", 100).         rotation("nav_bar",   0.0).
anchor("nav_bar", 0.0, 0.0).   opacity("nav_bar", 0.97).
sticky("nav_bar", 0.0).

// nav_logo: left-aligned, vertically centered
pos("nav_logo",   3.5, 16.0).  size("nav_logo",  14.0,  40.0).
layer("nav_logo", 101).         rotation("nav_logo",  0.0).
anchor("nav_logo", 0.0, 0.5).

// nav_menu: right block container
pos("nav_menu",   35.0, 20.0). size("nav_menu",  62.0,  32.0).
layer("nav_menu", 101).         rotation("nav_menu",  0.0).
anchor("nav_menu", 0.0, 0.5).

// Menu items — x positions evenly distributed across nav_menu right zone
pos("nav_item_home",         36.0, 24.0).  size("nav_item_home",          6.0, 24.0).
pos("nav_item_about",        44.0, 24.0).  size("nav_item_about",          6.0, 24.0).
pos("nav_item_services",     52.0, 24.0).  size("nav_item_services",       7.5, 24.0).
pos("nav_item_process",      61.0, 24.0).  size("nav_item_process",        7.0, 24.0).
pos("nav_item_projects",     69.5, 24.0).  size("nav_item_projects",       7.0, 24.0).
pos("nav_item_testimonials", 78.0, 24.0).  size("nav_item_testimonials",  10.5, 24.0).
pos("nav_item_contact",      90.5, 24.0).  size("nav_item_contact",        6.5, 24.0).

layer("nav_item_home", 102).         rotation("nav_item_home", 0.0).         anchor("nav_item_home", 0.5, 0.5).
layer("nav_item_about", 102).        rotation("nav_item_about", 0.0).        anchor("nav_item_about", 0.5, 0.5).
layer("nav_item_services", 102).     rotation("nav_item_services", 0.0).     anchor("nav_item_services", 0.5, 0.5).
layer("nav_item_process", 102).      rotation("nav_item_process", 0.0).      anchor("nav_item_process", 0.5, 0.5).
layer("nav_item_projects", 102).     rotation("nav_item_projects", 0.0).     anchor("nav_item_projects", 0.5, 0.5).
layer("nav_item_testimonials", 102). rotation("nav_item_testimonials", 0.0). anchor("nav_item_testimonials", 0.5, 0.5).
layer("nav_item_contact", 102).      rotation("nav_item_contact", 0.0).      anchor("nav_item_contact", 0.5, 0.5).

// Hover: subtle upward nudge
hover_translate("nav_item_home",         0.0, -3.0, 180.0, "ease-out").
hover_translate("nav_item_about",        0.0, -3.0, 180.0, "ease-out").
hover_translate("nav_item_services",     0.0, -3.0, 180.0, "ease-out").
hover_translate("nav_item_process",      0.0, -3.0, 180.0, "ease-out").
hover_translate("nav_item_projects",     0.0, -3.0, 180.0, "ease-out").
hover_translate("nav_item_testimonials", 0.0, -3.0, 180.0, "ease-out").
hover_translate("nav_item_contact",      0.0, -3.0, 180.0, "ease-out").

// Click → scroll to section
on_click("nav_item_home",         "scroll_to:sec_home").
on_click("nav_item_about",        "scroll_to:sec_about").
on_click("nav_item_services",     "scroll_to:sec_services").
on_click("nav_item_process",      "scroll_to:sec_process").
on_click("nav_item_projects",     "scroll_to:sec_projects").
on_click("nav_item_testimonials", "scroll_to:sec_testimonials").
on_click("nav_item_contact",      "scroll_to:sec_contact").

// Containment
contains("nav_bar",  "nav_logo").
contains("nav_bar",  "nav_menu").
contains("nav_menu", "nav_item_home").
contains("nav_menu", "nav_item_about").
contains("nav_menu", "nav_item_services").
contains("nav_menu", "nav_item_process").
contains("nav_menu", "nav_item_projects").
contains("nav_menu", "nav_item_testimonials").
contains("nav_menu", "nav_item_contact").

in_section("nav_bar",               "sec_home").
in_section("nav_logo",              "sec_home").
in_section("nav_menu",              "sec_home").
in_section("nav_item_home",         "sec_home").
in_section("nav_item_about",        "sec_home").
in_section("nav_item_services",     "sec_home").
in_section("nav_item_process",      "sec_home").
in_section("nav_item_projects",     "sec_home").
in_section("nav_item_testimonials", "sec_home").
in_section("nav_item_contact",      "sec_home").


// ════════════════════════════════════════════════════════════
// HERO   y 0 – 900
// ════════════════════════════════════════════════════════════
//
//  ┌──────────────────┬───────────────────────────────────────────┐
//  │                  │ ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ │ hero_bg_image
//  │  HEADLINE        │         ┌──────────────────┐             ░ │ bleeds right ~10vw
//  │    LINE ONE      │         │  hero_image_frame│             ░ │ rot -3°
//  │      LINE TWO    │         │  rot +2.5°       │             ░ │
//  │  ─────────────   │         │                  │             ░ │
//  │  tagline         │         └──────────────────┘               │
//  │  [VIEW WORK ↗]   │                                            │
//  │                  ↓ scroll                                     │
//  └──────────────────────────────────────────────────────────────┘

element("hero_bg_image",    "image").
element("hero_image_frame", "image").
// SUPERSEDED by logo_* elements below — kept for parity reference
// element("hero_title_l1", "text").
// element("hero_title_l2", "text").

// ── Logo elements (typographic SVG art piece, left 30vw of hero) ──────────────
// SVG source: zelda_logo.html  viewBox="0 0 480 640"
// Page coords: x=3–33vw, y=100–680px  (scale=0.9 from SVG→page)
// logo_mask_photo parallaxes FASTER than logo_container → photo drifts behind letters
element("logo_container",  "overlay").  // clip-path container (30vw × 580px)
element("logo_mask_photo", "image").    // room photo visible only through letter shapes
element("logo_zel",        "text").     // "ZEL" — 185px/700wt, left-aligned
element("logo_da",         "text").     // "DA"  — 185px/300wt, right-aligned
element("logo_rule",       "rule").     // thin rule separating caps / lowercase group
element("logo_des",        "text").     // "des" — 92px/400wt/italic, left
element("logo_ign",        "text").     // "ign" — 92px/400wt/italic, indented
element("logo_co",         "text").     // "co." — 26px/300wt, tracked wide

element("hero_subtitle",    "text").
element("hero_rule",        "rule").
element("hero_cta",         "button").
element("hero_scroll_hint", "text").

// hero_bg_image: starts at 40vw, extends 72vw → bleeds 12vw off right edge
pos("hero_bg_image",    40.0,  0.0).   size("hero_bg_image",   72.0, 900.0).
layer("hero_bg_image",  1).             rotation("hero_bg_image",   0.0).
anchor("hero_bg_image", 0.0, 0.0).
parallax("hero_bg_image", 0.4).         // floats up at 60% of scroll speed

// hero_image_frame: inset portrait box, slightly tilted CW
pos("hero_image_frame",    52.0, 180.0).  size("hero_image_frame",   28.0, 470.0).
layer("hero_image_frame",  3).             rotation("hero_image_frame",  2.5).
anchor("hero_image_frame", 0.5, 0.5).
parallax("hero_image_frame", 0.65).

// ── LOGO: typographic SVG art piece — left 30vw ────────────────────────────
// Coordinate note: SVG viewBox 0 0 480 640 scaled to 30vw wide on page.
// Scale ≈ 0.9 (432px / 480px). All y values: page_y = 100 + svg_y × 0.9
//
//  ZEL          ← svg_y=190  page_y≈271  (baseline)  left-aligned
//                 svg_y=368  page_y≈431  right-aligned
//       DA
//  ─────────── ← svg_y=408  page_y≈467  thin rule
//  des          ← svg_y=494  page_y≈545  italic
//       ign     ← svg_y=584  page_y≈625  italic, indent 60svg→3.75vw
//  co.          ← svg_y=626  page_y≈663  tracked
//
// logo_container  — the clip-path owner; whole logo bounding box
pos("logo_container",   3.0,  100.0).  size("logo_container",  30.0, 580.0).
layer("logo_container", 5).             rotation("logo_container",  0.0).
anchor("logo_container", 0.0, 0.0).
scroll_fade_in("logo_container", 0.0, 1000.0, "ease-out").

// logo_mask_photo — the image that shows THROUGH the letter shapes (clipPath)
// Parallax at 0.55 (slower than the text at 1.0) → photo drifts behind windows
pos("logo_mask_photo",   3.0,  80.0).  size("logo_mask_photo",  30.0, 620.0).
layer("logo_mask_photo", 4).            rotation("logo_mask_photo",  0.0).
anchor("logo_mask_photo", 0.0, 0.0).
parallax("logo_mask_photo", 0.55).

// logo_zel — "ZEL"  185px/700wt  left-aligned
// box covers from cap-top to baseline: svg 57→190, page y=151→271
pos("logo_zel",   3.0, 151.0).  size("logo_zel",  29.0, 120.0).
layer("logo_zel", 6).            rotation("logo_zel",  0.0).
anchor("logo_zel", 0.0, 1.0).   // anchor at bottom = baseline
scroll_slide_in("logo_zel", -30.0, 0.0, 0.0, 900.0, "ease-out").

// logo_da — "DA"  185px/300wt  right-aligned
// box: svg 232→368, page y=309→431
pos("logo_da",   14.5, 309.0).  size("logo_da",  18.5, 122.0).
layer("logo_da", 6).             rotation("logo_da",  0.0).
anchor("logo_da", 1.0, 1.0).    // anchor at bottom-right = text-anchor end
scroll_slide_in("logo_da", 30.0, 0.0, 0.0, 1000.0, "ease-out").

// logo_rule — thin horizontal rule between cap group and lowercase group
// svg y=408, page y=467
pos("logo_rule",   3.0, 467.0).  size("logo_rule",  27.0,   1.0).
layer("logo_rule", 6).            rotation("logo_rule",  0.0).
anchor("logo_rule", 0.0, 0.5).

// logo_des — "des"  92px/400wt/italic  left-aligned
// svg y=494, page y=545. Cap top: 545-66=479
pos("logo_des",   3.0, 479.0).  size("logo_des",  21.0, 66.0).
layer("logo_des", 6).            rotation("logo_des",  0.0).
anchor("logo_des", 0.0, 1.0).
scroll_slide_in("logo_des", -20.0, 0.0, 0.0, 800.0, "ease-out").

// logo_ign — "ign"  92px/400wt/italic  indented 3.75vw (svg x=60 → 60/480*30=3.75vw)
// svg y=584, page y=625. Cap top: 625-66=559
pos("logo_ign",   6.75, 559.0).  size("logo_ign",  17.25, 66.0).
layer("logo_ign", 6).             rotation("logo_ign",  0.0).
anchor("logo_ign", 0.0, 1.0).
scroll_slide_in("logo_ign", -20.0, 0.0, 0.0, 900.0, "ease-out").

// logo_co — "co."  26px/300wt  tracked wide  left-aligned
// svg y=626, page y=663. Cap top: 663-19=644
pos("logo_co",   3.0, 644.0).  size("logo_co",  9.0, 22.0).
layer("logo_co", 6).            rotation("logo_co",  0.0).
anchor("logo_co", 0.0, 1.0).
scroll_fade_in("logo_co", 0.0, 700.0, "ease-out").

in_section("logo_container",  "sec_home").
in_section("logo_mask_photo", "sec_home").
in_section("logo_zel",        "sec_home").
in_section("logo_da",         "sec_home").
in_section("logo_rule",       "sec_home").
in_section("logo_des",        "sec_home").
in_section("logo_ign",        "sec_home").
in_section("logo_co",         "sec_home").

contains("logo_container", "logo_mask_photo").
contains("logo_container", "logo_zel").
contains("logo_container", "logo_da").
contains("logo_container", "logo_rule").
contains("logo_container", "logo_des").
contains("logo_container", "logo_ign").
contains("logo_container", "logo_co").

// ── (Superseded generic title placeholders — archived below) ─────────────────
// pos("hero_title_l1",  3.5, 220.0).  size("hero_title_l1",  46.0, 118.0).  rot=-3°
// pos("hero_title_l2",  9.0, 346.0).  size("hero_title_l2",  50.0, 128.0).  rot=-3°

// hero_rule: thin horizontal rule between headline and tagline
pos("hero_rule",    3.5, 494.0).  size("hero_rule",   20.0,   1.0).
layer("hero_rule",  5).            rotation("hero_rule",   0.0).
anchor("hero_rule", 0.0, 0.5).

// hero_subtitle: small elegant tagline
pos("hero_subtitle",    3.5, 510.0).  size("hero_subtitle",   32.0,  36.0).
layer("hero_subtitle",  5).            rotation("hero_subtitle",   0.0).
anchor("hero_subtitle", 0.0, 0.5).
scroll_fade_in("hero_subtitle", 0.0, 700.0, "ease-out").

// hero_cta: primary CTA button — magnetic, scales on hover
pos("hero_cta",    3.5, 576.0).   size("hero_cta",   14.0,  52.0).
layer("hero_cta",  5).             rotation("hero_cta",   0.0).
anchor("hero_cta", 0.5, 0.5).
hover_translate("hero_cta", 0.0, -4.0, 240.0, "ease-out").
hover_scale("hero_cta", 1.04, 1.04, 240.0, "ease-out").
magnetic("hero_cta", 0.3, 80.0).
on_click("hero_cta", "scroll_to:sec_projects").

// hero_scroll_hint: bottom-center micro-label, bobs vertically
pos("hero_scroll_hint",    47.0, 838.0).  size("hero_scroll_hint",   6.0,  36.0).
layer("hero_scroll_hint",  5).             rotation("hero_scroll_hint",   0.0).
anchor("hero_scroll_hint", 0.5, 0.5).
hover_jiggle("hero_scroll_hint", "y", 4.0, 1.5).

in_section("hero_bg_image",    "sec_home").
in_section("hero_image_frame", "sec_home").
in_section("hero_title_l1",    "sec_home").
in_section("hero_title_l2",    "sec_home").
in_section("hero_rule",        "sec_home").
in_section("hero_subtitle",    "sec_home").
in_section("hero_cta",         "sec_home").
in_section("hero_scroll_hint", "sec_home").


// ════════════════════════════════════════════════════════════
// ABOUT   y 900 – 1700   (extended to 800px to contain full rotated magazine)
// ════════════════════════════════════════════════════════════
//
//  CONCEPT: An open magazine, rotated -3.5°, floating on top of the page.
//  The magazine bleeds upward 60px into the hero section (y=840).
//  Drop shadow makes it feel physically present.
//  Source: about_magazine.html
//
//  Coordinate origin of magazine bounding box (before rotation):
//    x: 9vw,  y: 840px   (centered: 9 + 82/2 = 50vw center)
//    w: 82vw, h: 700px   → bottom at y=1540 (within about section)
//
//  ┌────────────────────────────────────────────────┐ y=840 (rot -3.5°)
//  │ INTERIORS QUARTERLY        Spring/Summer 2026  │
//  │ ┌─────────────────────┐║┌───────────────────┐  │
//  │ │                     │║│ Profile · Designer │  │
//  │ │   [photo — left     │║│                    │  │
//  │ │    page, full bleed]│║│ Spaces That        │  │
//  │ │                     │║│ Tell Your Story    │  │
//  │ │                     │║│ ─────────────────  │  │
//  │ │                     │║│ Body copy ┊ col 2  │  │
//  │ │                  12 │║│ pull quote ──────  │  │
//  │ └─────────────────────┘║└─────────────────13─┘  │
//  └────────────────────────────────────────────────┘
//   ║ = spine (22px, gradient, inset shadow)

// ── Section background ────────────────────────────────────────────────────
element("about_bg",           "section").

// ── Magazine scene (outer wrapper — applies rotation + shadow) ───────────
element("about_mag_scene",    "overlay").   // rot=-3.5°, has drop-shadow

// ── Magazine pages ────────────────────────────────────────────────────────
element("about_mag_left",     "image").     // full-bleed photo, left page
element("about_mag_spine",    "rule").      // center spine (gradient bar)
element("about_mag_right",    "section").   // right page (cream background)

// ── Right page content (children of about_mag_right) ─────────────────────
element("about_mag_header",   "text").      // top header: section tag + issue
element("about_mag_headline", "text").      // big headline "Spaces That Tell…"
element("about_mag_byline",   "text").      // byline
element("about_mag_rule",     "rule").      // thin gold→cream rule
element("about_mag_body",     "text").      // 2-column body text
element("about_mag_pullquote","text").      // italic pull quote with gold border
element("about_mag_signature","text").      // "— Zelda [Last Name]"

// ── Section label (left margin, outside magazine) ─────────────────────────
element("about_label",        "text").      // "ABOUT" rot=-90°

// Section background — extended to 800px for rotated magazine
pos("about_bg",   0.0,  900.0).  size("about_bg",  100.0, 800.0).
layer("about_bg", 0).             rotation("about_bg",   0.0).
anchor("about_bg", 0.0, 0.0).

// "ABOUT" rotated label on left margin
pos("about_label",    1.5, 1230.0).  size("about_label",    6.0,  24.0).
layer("about_label",  12).            rotation("about_label",  -90.0).
anchor("about_label", 0.5, 0.5).

// ── Magazine scene ─────────────────────────────────────────────────────────
// Bounding box is BEFORE rotation. rot=-3.5° so visually it tilts CCW.
// Center x = 9 + 82/2 = 50vw. Bleeds 60px up into hero (y=840).
// drop-shadow applied in CSS — not a controlnet primitive, noted here for reference.
pos("about_mag_scene",   9.0,  840.0).  size("about_mag_scene",  82.0, 700.0).
layer("about_mag_scene", 10).            rotation("about_mag_scene",  -3.5).
anchor("about_mag_scene", 0.5, 0.0).    // rotates around top-center
scroll_fade_in("about_mag_scene",  0.05, 900.0, "ease-out").
scroll_slide_in("about_mag_scene", 0.0, 40.0, 0.05, 900.0, "ease-out").

// ── Left page: full-bleed photo ────────────────────────────────────────────
// occupies left ~half of magazine scene (minus spine)
// x: same as scene start (9vw), w: ~39vw
pos("about_mag_left",   9.0,  840.0).  size("about_mag_left",   39.0, 700.0).
layer("about_mag_left", 11).            rotation("about_mag_left",  0.0).
anchor("about_mag_left", 0.0, 0.0).

// ── Spine ──────────────────────────────────────────────────────────────────
// 1.5vw wide, 22px physical = ~1.5vw at 1440px
pos("about_mag_spine",   48.0,  840.0).  size("about_mag_spine",  1.5, 700.0).
layer("about_mag_spine", 11).             rotation("about_mag_spine",  0.0).
anchor("about_mag_spine", 0.0, 0.0).

// ── Right page ─────────────────────────────────────────────────────────────
// x: spine_right = 48+1.5 = 49.5vw, w: remaining 82-(39+1.5) = 41.5vw
pos("about_mag_right",   49.5,  840.0).  size("about_mag_right",  41.5, 700.0).
layer("about_mag_right", 11).             rotation("about_mag_right",  0.0).
anchor("about_mag_right", 0.0, 0.0).

// ── Right page content (coords within magazine_right; y relative to page top 840) ─
pos("about_mag_header",    49.5,  872.0).  size("about_mag_header",    41.5, 18.0).
layer("about_mag_header",  12).             rotation("about_mag_header",   0.0).
anchor("about_mag_header", 0.0, 0.0).

pos("about_mag_headline",  49.5,  920.0).  size("about_mag_headline",  41.5, 100.0).
layer("about_mag_headline",12).             rotation("about_mag_headline",  0.0).
anchor("about_mag_headline",0.0, 0.0).

pos("about_mag_byline",    49.5, 1028.0).  size("about_mag_byline",    41.5, 16.0).
layer("about_mag_byline",  12).             rotation("about_mag_byline",   0.0).
anchor("about_mag_byline", 0.0, 0.0).

pos("about_mag_rule",      49.5, 1050.0).  size("about_mag_rule",      38.0,  1.0).
layer("about_mag_rule",    12).             rotation("about_mag_rule",     0.0).
anchor("about_mag_rule",   0.0, 0.5).

pos("about_mag_body",      49.5, 1068.0).  size("about_mag_body",      41.5, 320.0).
layer("about_mag_body",    12).             rotation("about_mag_body",     0.0).
anchor("about_mag_body",   0.0, 0.0).

pos("about_mag_pullquote", 49.5, 1180.0).  size("about_mag_pullquote", 38.0,  60.0).
layer("about_mag_pullquote",12).            rotation("about_mag_pullquote",  0.0).
anchor("about_mag_pullquote",0.0, 0.0).

pos("about_mag_signature", 49.5, 1490.0).  size("about_mag_signature", 30.0,  22.0).
layer("about_mag_signature",12).            rotation("about_mag_signature",  0.0).
anchor("about_mag_signature",0.0, 0.0).

// Containment
contains("about_mag_scene", "about_mag_left").
contains("about_mag_scene", "about_mag_spine").
contains("about_mag_scene", "about_mag_right").
contains("about_mag_right", "about_mag_header").
contains("about_mag_right", "about_mag_headline").
contains("about_mag_right", "about_mag_byline").
contains("about_mag_right", "about_mag_rule").
contains("about_mag_right", "about_mag_body").
contains("about_mag_right", "about_mag_pullquote").
contains("about_mag_right", "about_mag_signature").

// (about_signature superseded by about_mag_signature inside magazine)

in_section("about_bg",            "sec_about").
in_section("about_label",         "sec_about").
in_section("about_mag_scene",     "sec_about").
in_section("about_mag_left",      "sec_about").
in_section("about_mag_spine",     "sec_about").
in_section("about_mag_right",     "sec_about").
in_section("about_mag_header",    "sec_about").
